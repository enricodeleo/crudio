{
  "name": "@enricodeleo/crudio",
  "version": "1.0.0",
  "description": "Turn an OpenAPI spec into a working CRUD backend with persistence and seeding",
  "author": "Enrico Deleo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enricodeleo/crudio.git"
  },
  "homepage": "https://github.com/enricodeleo/crudio#readme",
  "bugs": {
    "url": "https://github.com/enricodeleo/crudio/issues"
  },
  "type": "module",
  "bin": {
    "crudio": "bin/crudio.js"
  },
  "exports": {
    ".": "./src/app.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/crudio.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "openapi",
    "crud",
    "mock",
    "api",
    "swagger"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@readme/openapi-parser": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
