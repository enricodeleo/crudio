{
  "name": "crudio",
  "version": "0.1.0",
  "description": "Turn an OpenAPI spec into a working CRUD backend",
  "type": "module",
  "bin": {
    "crudio": "./bin/crudio.js"
  },
  "exports": {
    ".": "./src/app.js"
  },
  "scripts": {
    "start": "node bin/crudio.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "openapi",
    "crud",
    "mock",
    "api",
    "swagger"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@readme/openapi-parser": "^6.0.1",
    "ajv": "^8.18.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
